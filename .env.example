# Application Settings
PORT=3000
NODE_ENV=development

# Core AWS Configuration
AWS_REGION=us-east-1

# Optional: Set these if you aren't using an existing AWS CLI config (`aws configure`) locally
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY

# DynamoDB Configuration
# Note: Ensure this matches the table name deployed in your AWS account
PATIENTS_TABLE=PatientsTable

# OpenSearch Configuration
# Example: https://search-[your-domain].us-east-1.es.amazonaws.com
OPENSEARCH_NODE=https://localhost:9200

# AWS Cognito Configuration
# Example: us-east-1_abcdefghi
COGNITO_USER_POOL_ID=YOUR_COGNITO_USER_POOL_ID
COGNITO_CLIENT_ID=YOUR_COGNITO_APP_CLIENT_ID
